# Production on Vercel should be a PostgreSQL connection string, not SQLite.
# Example shape: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
APP_URL="http://localhost:3000"
SESSION_SECRET="replace-with-a-long-random-secret"
SMS_API_KEY=""
