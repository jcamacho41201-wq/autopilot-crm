generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  plan               String              @default("Starter")
  subscriptionStatus String              @default("trialing")
  bookingLink        String              @default("")
  timezone           String              @default("America/New_York")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  users              User[]
  customers          Customer[]
  appointments       Appointment[]
  inventoryItems     InventoryItem[]
  reminderRules      ReminderRule[]
  services           Service[]
  servicePackages    ServicePackage[]
  technicians        Technician[]
  scanLogs           InventoryScanLog[]
  serviceRecords     ServiceRecord[]
  opportunities      DeferredOpportunity[]
  quotes             Quote[]
}

model User {
  id           String    @id @default(cuid())
  shopId       String
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("MECHANIC")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  shop         Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id                 String        @id @default(cuid())
  shopId             String
  name               String
  phone              String
  email              String?
  notes              String?
  communicationPrefs String        @default("SMS")
  lifetimeSpend      Float         @default(0)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  shop               Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  vehicles           Vehicle[]
  appointments       Appointment[]
  serviceRecords     ServiceRecord[]
  quotes             Quote[]
}

model Vehicle {
  id                  String                @id @default(cuid())
  customerId          String
  year                Int
  make                String
  model               String
  trim                String?
  vehicleType         String?
  vin                 String?
  licensePlate        String?
  notes               String?
  currentMileage      Int
  mileageUpdatedAt    DateTime?
  estimatedMilesYear  Int                   @default(12000)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  customer            Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  mileageLogs         MileageLog[]
  maintenanceItems    MaintenanceItem[]
  serviceRecords      ServiceRecord[]
  appointments        Appointment[]
  opportunities       DeferredOpportunity[]
  quotes              Quote[]
}

model MileageLog {
  id        String   @id @default(cuid())
  vehicleId String
  mileage   Int
  loggedAt  DateTime @default(now())
  source    String   @default("service")
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Service {
  id                    String            @id @default(cuid())
  shopId                String
  name                  String
  category              String            @default("Custom")
  defaultMileageInterval Int
  defaultTimeIntervalMonths Int
  averagePrice          Float
  defaultReminderThreshold Int             @default(20)
  description           String?
  recommendedNotes      String?
  status                String            @default("ACTIVE")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  shop                  Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  maintenanceItems      MaintenanceItem[]
  appointmentServices   AppointmentService[]
  packageItems          ServicePackageItem[]
}

model ServicePackage {
  id          String               @id @default(cuid())
  shopId      String
  name        String
  description String?
  status      String               @default("ACTIVE")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  shop        Shop                 @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items       ServicePackageItem[]
}

model ServicePackageItem {
  id        String         @id @default(cuid())
  packageId String
  serviceId String
  package   ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service   Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([packageId, serviceId])
}

model MaintenanceItem {
  id                         String          @id @default(cuid())
  vehicleId                  String
  serviceId                  String?
  name                       String
  lastCompletedDate          DateTime
  lastCompletedMileage       Int
  mileageInterval            Int
  timeIntervalMonths         Int
  averagePrice               Float
  status                     String          @default("ACTIVE")
  overrideDueMileage         Int?
  overrideDueDate            DateTime?
  remindersEnabled           Boolean         @default(true)
  reminderThresholdPercentage Int             @default(20)
  customNotes                String?
  vehicle                    Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  service                    Service?        @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  reminders                  ReminderLog[]
  appointmentServices        AppointmentService[]
}

model Appointment {
  id                 String            @id @default(cuid())
  shopId             String
  customerId         String
  vehicleId          String
  technicianId       String?
  scheduledAt        DateTime
  durationMinutes    Int               @default(60)
  status             String            @default("BOOKED")
  serviceName        String
  estimatedRevenue   Float             @default(0)
  estimatedJobHours  Float             @default(1)
  actualJobHours     Float?
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  shop               Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer           Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle            Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  technician         Technician?       @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  services           AppointmentService[]
}

model AppointmentService {
  id                       String           @id @default(cuid())
  appointmentId            String
  serviceTemplateId        String?
  maintenanceItemId        String?
  serviceName              String
  estimatedPrice           Float            @default(0)
  estimatedDurationMinutes Int              @default(60)
  status                   String           @default("SCHEDULED")
  createdAt                DateTime         @default(now())
  appointment              Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  serviceTemplate          Service?         @relation(fields: [serviceTemplateId], references: [id], onDelete: SetNull)
  maintenanceItem          MaintenanceItem? @relation(fields: [maintenanceItemId], references: [id], onDelete: SetNull)
}

model ServiceRecord {
  id             String                @id @default(cuid())
  shopId         String
  customerId     String?
  vehicleId      String
  technicianId   String?
  serviceDate    DateTime              @default(now())
  mileage        Int
  summary        String
  notes          String?
  revenue        Float                 @default(0)
  nextRecommendedService String?
  nextRecommendedMileage Int?
  createdAt      DateTime              @default(now())
  shop           Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer       Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vehicle        Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  technician     Technician?           @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  opportunities  DeferredOpportunity[]
  scanLogs       InventoryScanLog[]
  quotes         Quote[]
}

model Quote {
  id              String       @id @default(cuid())
  shopId          String
  customerId      String
  vehicleId       String
  serviceRecordId String?
  quoteNumber     String
  status          String       @default("DRAFT")
  issueDate       DateTime     @default(now())
  expirationDate  DateTime
  subtotal        Float        @default(0)
  discountTotal   Float        @default(0)
  taxTotal        Float        @default(0)
  total           Float        @default(0)
  notes           String?
  shareToken      String       @unique
  approvedAt      DateTime?
  declinedAt      DateTime?
  callbackRequestedAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  shop            Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer        Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceRecord   ServiceRecord? @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)
  lines           QuoteLine[]

  @@unique([shopId, quoteNumber])
}

model QuoteLine {
  id          String   @id @default(cuid())
  quoteId     String
  lineType    String   @default("SERVICE")
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  total       Float    @default(0)
  sourceType  String?
  sourceId    String?
  createdAt   DateTime @default(now())
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model ReminderRule {
  id                  String  @id @default(cuid())
  shopId              String
  serviceName         String
  thresholdPercentage Int
  sendOverdue         Boolean @default(true)
  enabled             Boolean @default(true)
  messageTemplate     String?
  shop                Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ReminderLog {
  id                String          @id @default(cuid())
  maintenanceItemId String
  customerId        String?
  vehicleId         String?
  customerName      String
  phone             String
  message           String
  status            String          @default("MOCK_SENT")
  sentAt            DateTime        @default(now())
  maintenanceItem   MaintenanceItem @relation(fields: [maintenanceItemId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id               String             @id @default(cuid())
  shopId           String
  sku              String
  barcode          String             @unique
  name             String
  category         String
  quantityOnHand   Float
  unitType         String
  reorderThreshold Float
  cost             Float
  supplier         String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  shop             Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scanLogs         InventoryScanLog[]
}

model InventoryScanLog {
  id              String          @id @default(cuid())
  shopId          String
  inventoryItemId String
  serviceRecordId String?
  quantityUsed    Float
  barcode         String
  scannedBy       String
  scannedAt       DateTime        @default(now())
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem   @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  serviceRecord   ServiceRecord?  @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)
}

model DeferredOpportunity {
  id              String            @id @default(cuid())
  shopId          String
  vehicleId       String
  serviceRecordId String?
  description     String
  estimatedRevenue Float
  followUpDate    DateTime
  status          String            @default("OPEN")
  createdAt       DateTime          @default(now())
  shop            Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceRecord   ServiceRecord?    @relation(fields: [serviceRecordId], references: [id], onDelete: SetNull)
}

model Technician {
  id           String        @id @default(cuid())
  shopId       String
  name         String
  role         String        @default("Technician")
  standardHours Float        @default(0)
  actualHours   Float        @default(0)
  jobsCompleted Int          @default(0)
  hourlyRate    Float        @default(0)
  reworkCount   Int          @default(0)
  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  serviceRecords ServiceRecord[]
}
